# Supabase (majburiy — bo‘lmasa namoyish ma’lumotlari ishlatiladi)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: savatchadan Supabase ga buyurtma (order_requests). Anon kalit bilan yozilmaydi.
# TELEGRAM_BOT_TOKEN=123456:ABC...   (backend BOT_TOKEN bilan bir xil)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin paneli (/admin, /admin/shops) — faqat shu Telegram user id lar (vergul bilan)
# ADMIN_TELEGRAM_IDS=123456789,987654321
#
# Sotuvchi API: shops.owner_telegram_username = Telegram username (@ yoki @siz)
# Mahsulot/xizmat: schema-reference.sql dagi products ustunlari (product_type, stock, service_type) ni Supabase da ishga tushiring.
# Rasm yuklash: Storage da public bucket nomi (default: product-images)
# SUPABASE_PRODUCT_IMAGES_BUCKET=product-images

# Ixtiyoriy: AI sovg‘a sahifasi uchun (/api/ai/suggest)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Backend API — botdagi rol bilan sinxron (JWT). Bo‘sh qoldirsangiz, rol Supabase users dan o‘qiladi.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
